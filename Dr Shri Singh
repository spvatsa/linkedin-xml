<style>
  :root{
    --navy-950:#0A1526;
    --navy-900:#0F213B;
    --navy-800:#173257;
    --navy-700:#1D3A5F;
    --slate-500:#5B7A99;
    --slate-300:#9AB0C4;
    --teal-600:#1F8A85;
    --teal-500:#2AA39D;
    --amber-500:#B98A3D;
    --bg:#F4F6F8;
    --paper:#FFFFFF;
    --ink:#152232;
    --ink-soft:#495B6E;
    --line:#DDE4EA;
    --radius:2px;
  }
  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    margin:0;
    background:var(--bg);
    color:var(--ink);
    font-family:'Inter',sans-serif;
    -webkit-font-smoothing:antialiased;
    line-height:1.6;
  }
  h1,h2,h3,.display{
    font-family:'Newsreader',serif;
    font-weight:500;
    letter-spacing:-0.01em;
    color:var(--navy-950);
  }
  .mono{ font-family:'IBM Plex Mono',monospace; letter-spacing:0.02em; }
  a{ color:inherit; }
  .wrap{ max-width:1080px; margin:0 auto; padding:0 32px; }
  @media (max-width:640px){ .wrap{ padding:0 20px; } }

  /* ---------- Skip / focus ---------- */
  a:focus-visible, button:focus-visible{
    outline:2px solid var(--teal-600);
    outline-offset:3px;
  }
  .skip-link{
    position:absolute; left:-999px; top:0;
    background:var(--navy-950); color:#fff; padding:10px 16px; z-index:200;
  }
  .skip-link:focus{ left:16px; top:16px; }

  /* ---------- Nav ---------- */
  header.nav{
    position:sticky; top:0; z-index:100;
    background:rgba(244,246,248,0.92);
    backdrop-filter:blur(8px);
    border-bottom:1px solid var(--line);
  }
  .nav-inner{
    display:flex; align-items:center; justify-content:space-between;
    padding:18px 32px; max-width:1080px; margin:0 auto;
  }
  .nav-name{ font-family:'Newsreader',serif; font-size:18px; font-weight:600; color:var(--navy-950); }
  .nav-links{ display:flex; gap:28px; list-style:none; margin:0; padding:0; }
  .nav-links a{
    text-decoration:none; font-size:13px; letter-spacing:0.04em; text-transform:uppercase;
    color:var(--ink-soft); font-weight:500;
    padding-bottom:3px; border-bottom:1px solid transparent;
    transition:border-color .2s ease, color .2s ease;
  }
  .nav-links a:hover{ color:var(--navy-950); border-color:var(--teal-600); }
  .nav-cta{
    font-size:13px; letter-spacing:0.03em; text-transform:uppercase; font-weight:600;
    background:var(--navy-950); color:#fff; padding:9px 16px; text-decoration:none;
    border-radius:var(--radius);
  }
  @media (max-width:760px){ .nav-links{ display:none; } }

  /* ---------- Hero ---------- */
  .hero{
    background:
      linear-gradient(180deg, var(--navy-950) 0%, var(--navy-900) 62%, var(--navy-800) 100%);
    color:#EAF0F5;
    position:relative;
    overflow:hidden;
  }
  .hero-inner{
    max-width:1080px; margin:0 auto; padding:88px 32px 72px;
    display:grid; grid-template-columns:1fr; gap:36px;
  }
  .hero-signal{
    position:absolute; top:0; right:0; bottom:0; width:46%;
    opacity:0.55; pointer-events:none;
  }
  .eyebrow{
    font-family:'IBM Plex Mono',monospace; font-size:12px; letter-spacing:0.14em;
    text-transform:uppercase; color:var(--teal-500); margin:0 0 18px;
  }
  .hero h1{
    color:#fff; font-size:clamp(34px,5vw,54px); line-height:1.08; margin:0 0 14px; max-width:820px;
  }
  .hero .role{
    font-size:clamp(17px,2vw,20px); color:var(--slate-300); font-weight:400; margin:0 0 26px; max-width:640px;
  }
  .hero .lede{
    max-width:640px; font-size:16px; color:#C7D5E1; margin:0 0 34px;
  }
  .hero-actions{ display:flex; gap:14px; flex-wrap:wrap; }
  .btn-primary{
    background:var(--teal-600); color:#04140F; text-decoration:none; font-weight:600;
    padding:13px 22px; border-radius:var(--radius); font-size:14px; letter-spacing:0.01em;
    transition:background .2s ease;
  }
  .btn-primary:hover{ background:var(--teal-500); }
  .btn-ghost{
    border:1px solid rgba(255,255,255,0.28); color:#fff; text-decoration:none; font-weight:500;
    padding:13px 22px; border-radius:var(--radius); font-size:14px;
    transition:border-color .2s ease, background .2s ease;
  }
  .btn-ghost:hover{ border-color:#fff; background:rgba(255,255,255,0.06); }

  .stat-band{
    border-top:1px solid rgba(255,255,255,0.14);
    margin-top:52px; padding-top:34px;
    display:grid; grid-template-columns:repeat(4,1fr); gap:24px;
