  .stat-num{ font-family:'Newsreader',serif; font-size:clamp(26px,3.4vw,36px); color:#fff; font-weight:500; }
  .stat-label{ font-size:12.5px; color:var(--slate-300); margin-top:4px; max-width:20ch; }

  /* ---------- Section shell ---------- */
  section{ padding:76px 0; }
  .section-head{ margin-bottom:38px; max-width:640px; }
  .section-num{
    font-family:'IBM Plex Mono',monospace; font-size:12px; color:var(--teal-600);
    letter-spacing:0.1em; text-transform:uppercase; margin:0 0 10px;
