  .section-head h2{ font-size:clamp(24px,3vw,32px); margin:0 0 12px; }
  .section-head p{ color:var(--ink-soft); font-size:15px; margin:0; }

  /* ---------- About ---------- */
  .about{ background:var(--paper); border-top:1px solid var(--line); border-bottom:1px solid var(--line); }
  .about-grid{ display:grid; grid-template-columns:1fr 1fr; gap:56px; align-items:start; }
  @media (max-width:800px){ .about-grid{ grid-template-columns:1fr; gap:28px; } }
  .about p{ font-size:15.5px; color:var(--ink-soft); margin:0 0 16px; }
  .cert-list{ list-style:none; margin:0; padding:0; display:flex; flex-wrap:wrap; gap:8px; }
  .cert-list li{
    font-family:'IBM Plex Mono',monospace; font-size:12px; color:var(--navy-800);
    background:var(--bg); border:1px solid var(--line); padding:6px 10px; border-radius:var(--radius);
  }
  .about-label{
    font-family:'IBM Plex Mono',monospace; font-size:11.5px; letter-spacing:0.1em; text-transform:uppercase;
    color:var(--slate-500); margin:0 0 14px;
  }

  /* ---------- Competencies ---------- */
  .tag-grid{ display:flex; flex-wrap:wrap; gap:10px; }
  .tag{
    font-size:13.5px; color:var(--navy-900); background:var(--paper); border:1px solid var(--line);
    padding:9px 14px; border-radius:var(--radius);
  }
  .tech-groups{ display:grid; grid-template-columns:repeat(3,1fr); gap:28px; margin-top:12px; }
  @media (max-width:800px){ .tech-groups{ grid-template-columns:1fr 1fr; } }
  @media (max-width:560px){ .tech-groups{ grid-template-columns:1fr; } }
  .tech-card{ background:var(--paper); border:1px solid var(--line); padding:22px 20px; border-radius:var(--radius); }
  .tech-card h3{ font-size:14px; margin:0 0 12px; text-transform:uppercase; letter-spacing:0.03em; color:var(--navy-800); font-family:'Inter',sans-serif; font-weight:600; }
  .tech-card p{ font-size:13.5px; color:var(--ink-soft); margin:0; line-height:1.65; }

  /* ---------- Experience timeline ---------- */
  .timeline{ position:relative; margin-top:8px; }
  .timeline::before{
    content:''; position:absolute; left:11px; top:6px; bottom:6px; width:1px; background:var(--line);
  }
  .tl-item{ position:relative; padding-left:44px; margin-bottom:44px; }
  .tl-item:last-child{ margin-bottom:0; }
  .tl-node{
    position:absolute; left:0; top:4px; width:24px; height:24px; border-radius:50%;
    background:var(--paper); border:1px solid var(--teal-600);
    display:flex; align-items:center; justify-content:center;
  }
  .tl-node::after{ content:''; width:8px; height:8px; border-radius:50%; background:var(--teal-600); }
  .tl-current .tl-node{ background:var(--teal-600); }
  .tl-current .tl-node::after{ background:#fff; }
  .tl-meta{
    display:flex; flex-wrap:wrap; align-items:baseline; gap:10px; margin-bottom:6px;
  }
  .tl-role{ font-family:'Newsreader',serif; font-size:19px; color:var(--navy-950); font-weight:600; margin:0; }
  .tl-dates{ font-family:'IBM Plex Mono',monospace; font-size:12px; color:var(--teal-600); }
  .tl-org{ font-size:14px; color:var(--ink-soft); margin:0 0 14px; font-weight:500; }
  .tl-bullets{ margin:0; padding-left:18px; }
  .tl-bullets li{ font-size:14.5px; color:var(--ink-soft); margin-bottom:8px; }
  .tl-bullets li::marker{ color:var(--teal-600); }

  /* ---------- Education / Certs ---------- */
  .edu-cert{ background:var(--paper); border-top:1px solid var(--line); border-bottom:1px solid var(--line); }
  .ec-grid{ display:grid; grid-template-columns:1.3fr 1fr; gap:56px; }
  @media (max-width:800px){ .ec-grid{ grid-template-columns:1fr; gap:36px; } }
  .edu-item{ padding:16px 0; border-bottom:1px solid var(--line); }
  .edu-item:last-child{ border-bottom:none; }
  .edu-degree{ font-family:'Newsreader',serif; font-size:16.5px; color:var(--navy-950); margin:0 0 2px; }
  .edu-school{ font-size:13.5px; color:var(--ink-soft); margin:0; }
  .cert-badges{ display:flex; flex-wrap:wrap; gap:10px; align-content:flex-start; }
  .badge{
    font-family:'IBM Plex Mono',monospace; font-size:12px; color:#fff; background:var(--navy-900);
    padding:8px 12px; border-radius:var(--radius);
  }

  /* ---------- Contact / Footer ---------- */
  footer{
    background:var(--navy-950); color:#EAF0F5; padding:64px 0 40px;
  }
  .contact-grid{ display:grid; grid-template-columns:1.2fr 1fr; gap:40px; align-items:start; }
  @media (max-width:760px){ .contact-grid{ grid-template-columns:1fr; } }
  footer h2{ color:#fff; font-size:clamp(24px,3vw,30px); margin:0 0 14px; }
  footer p{ color:var(--slate-300); font-size:15px; max-width:46ch; margin:0 0 26px; }
  .contact-list{ list-style:none; margin:0; padding:0; }
  .contact-list li{ margin-bottom:14px; }
  .contact-list a{
    text-decoration:none; color:#fff; font-size:15px; display:flex; align-items:center; gap:10px;
  }
  .contact-list a:hover{ color:var(--teal-500); }
  .contact-list .k{ font-family:'IBM Plex Mono',monospace; font-size:11px; color:var(--slate-500); text-transform:uppercase; letter-spacing:0.08em; min-width:56px; display:inline-block; }
  .foot-bottom{
    margin-top:56px; padding-top:24px; border-top:1px solid rgba(255,255,255,0.12);
    font-size:12.5px; color:var(--slate-500); display:flex; justify-content:space-between; flex-wrap:wrap; gap:10px;
  }

  ::selection{ background:var(--teal-600); color:#fff; }

  @media (prefers-reduced-motion: reduce){
    html{ scroll-behavior:auto; }
    *{ transition:none !important; }
  }
</style>
</head>
